# Copy to .env and edit — never commit .env
APP_ENV=development

# Desktop Postgres (Option C)
DATABASE_URL=postgresql+asyncpg://plantpal:plantpal@localhost:5432/plantpal

# Docker Compose — use host "db" instead of "localhost"
# DATABASE_URL=postgresql+asyncpg://plantpal:plantpal@db:5432/plantpal

POSTGRES_USER=plantpal
POSTGRES_PASSWORD=plantpal
POSTGRES_DB=plantpal
